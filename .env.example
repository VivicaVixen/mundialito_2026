# Variable de entorno (se configura en Vercel → Settings → Environment Variables).
#
# RAPIDAPI_KEY: clave de la API del Mundial 2026 en RapidAPI
# (wc26-live-football-api). La usa la función serverless /api/sync-matches para
# traer calendario y resultados. Queda SOLO en el servidor, nunca en el cliente.
RAPIDAPI_KEY="tu-clave-de-rapidapi"

# Nota: el login (Firebase Auth) y la base de datos (Firestore) usan la
# configuración pública del cliente en firebase-applet-config.json y NO
# requieren variables de entorno.
