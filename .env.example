# ─────────────────────────────────────────────────────────────
# Variables de entorno (se configuran en Vercel → Settings → Environment Variables)
# NO subas este archivo con valores reales. La clave privada es secreta.
# ─────────────────────────────────────────────────────────────

# Credenciales de la cuenta de servicio de Firebase (Admin SDK).
# Las obtienes en: Firebase Console → ⚙ Configuración del proyecto →
# Cuentas de servicio → "Generar nueva clave privada" (descarga un JSON).
FIREBASE_PROJECT_ID="mundialito2026-f4846"
FIREBASE_CLIENT_EMAIL="firebase-adminsdk-xxxxx@mundialito2026-f4846.iam.gserviceaccount.com"
# Pega el valor de "private_key" del JSON COMPLETO, entre comillas dobles,
# con los saltos de línea como \n literales (Vercel los convierte de nuevo).
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEv...\n-----END PRIVATE KEY-----\n"

# Secreto para proteger el endpoint /api/cron (recomendado).
# Inventa una cadena larga y aleatoria. Vercel la envía automáticamente
# en cada ejecución del cron. Si no la defines, el endpoint queda abierto.
CRON_SECRET="cadena-larga-aleatoria"

# (Opcional) Sobrescribe el id de la base de datos de Firestore.
# Vacío = se usa la base "(default)" del proyecto. No hace falta tocarlo.
# FIREBASE_DATABASE_ID=""
