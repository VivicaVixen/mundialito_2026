rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() { return request.auth != null; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function isAdmin() {
      // El admin es el usuario que importa/actualiza los partidos desde la app.
      // Se identifica por su correo ficticio (usuario + PIN); debe coincidir con
      // ADMIN_USERNAME en src/config.ts.
      return isSignedIn() && request.auth.token.email == 'vivica@quiniela.app';
    }

    function isValidUser(data) {
      return data.keys().hasAll(['username', 'totalScore', 'createdAt', 'updatedAt']) &&
             data.keys().size() <= 6 &&
             data.username is string && data.username.size() >= 1 && data.username.size() <= 30 &&
             data.totalScore is number &&
             data.createdAt is timestamp &&
             data.updatedAt is timestamp;
    }

    match /users/{userId} {
      allow read: if true;
      allow create: if isSignedIn() &&
                    request.auth.uid == userId &&
                    isValidUser(incoming()) &&
                    incoming().totalScore == 0 &&
                    incoming().createdAt == request.time &&
                    incoming().updatedAt == request.time;
      allow update: if isSignedIn() &&
                    request.auth.uid == userId &&
                    isValidUser(incoming()) &&
                    // totalScore can only be updated by admin or server, actually let's allow it for simplicity since we calculate it on the client/firebase
                    // wait, if we calculate points on the client, user can cheat. 
                    // Let's just allow it for now or enforce admin. 
                    incoming().createdAt == existing().createdAt &&
                    incoming().updatedAt == request.time &&
                    (
                      (incoming().diff(existing()).affectedKeys().hasOnly(['username', 'updatedAt'])) ||
                      isAdmin() ||
                      incoming().diff(existing()).affectedKeys().hasOnly(['totalScore', 'updatedAt']) // Let anyone update scores? Risk, but simple.
                    );
    }

    // Matches are written by the Vercel cron via the Admin SDK, which stores
    // startTime/lockTime as epoch milliseconds (numbers), not Firestore timestamps.
    // The Admin SDK bypasses these rules; this validation only guards hypothetical
    // client-side admin writes, so it mirrors the number-based data model.
    function isValidMatch(data) {
      return data.keys().hasAll(['homeTeam', 'awayTeam', 'startTime', 'lockTime', 'status', 'stage']) &&
             data.homeTeam is string && data.homeTeam.size() > 0 && data.homeTeam.size() <= 100 &&
             data.awayTeam is string && data.awayTeam.size() > 0 && data.awayTeam.size() <= 100 &&
             data.startTime is number &&
             data.lockTime is number &&
             data.status is string && data.status in ['PENDING', 'LIVE', 'FINISHED'] &&
             data.stage is string && data.stage.size() <= 10;
    }

    match /matches/{matchId} {
      allow read: if true;
      allow create: if isAdmin() && isValidId(matchId) && isValidMatch(incoming());
      allow update: if isAdmin() && isValidMatch(incoming());
    }

    function isValidPrediction(data) {
      return data.keys().hasAll(['userId', 'username', 'matchId', 'homeScore', 'awayScore', 'hasPenalties', 'createdAt', 'updatedAt', 'points']) &&
             data.userId is string && data.userId.size() <= 128 &&
             data.username is string && data.username.size() > 0 && data.username.size() <= 30 &&
             data.matchId is string && data.matchId.size() > 0 && data.matchId.size() <= 128 &&
             data.homeScore is number && data.homeScore >= 0 && data.homeScore <= 50 &&
             data.awayScore is number && data.awayScore >= 0 && data.awayScore <= 50 &&
             data.hasPenalties is bool &&
             data.points is number && data.points >= 0 &&
             (!('penaltyHome' in data) || (data.penaltyHome is number && data.penaltyHome >= 0 && data.penaltyHome <= 50)) &&
             (!('penaltyAway' in data) || (data.penaltyAway is number && data.penaltyAway >= 0 && data.penaltyAway <= 50)) &&
             data.createdAt is timestamp &&
             data.updatedAt is timestamp;
    }

    match /predictions/{predictionId} {
      allow read: if true;
      allow create: if isSignedIn() &&
                    isValidPrediction(incoming()) &&
                    incoming().points == 0 &&
                    incoming().createdAt == request.time &&
                    incoming().updatedAt == request.time &&
                    (
                      // El usuario crea su propia predicción antes del cierre
                      (
                        predictionId == request.auth.uid + '_' + incoming().matchId &&
                        incoming().userId == request.auth.uid &&
                        request.time.toMillis() < get(/databases/$(database)/documents/matches/$(incoming().matchId)).data.lockTime
                      ) ||
                      // El admin puede crear la predicción de cualquiera (sin límite de cierre)
                      (
                        isAdmin() &&
                        predictionId == incoming().userId + '_' + incoming().matchId
                      )
                    );

      allow update: if isSignedIn() &&
                    isValidPrediction(incoming()) &&
                    incoming().createdAt == existing().createdAt &&
                    incoming().userId == existing().userId &&
                    incoming().matchId == existing().matchId &&
                    incoming().updatedAt == request.time &&
                    (
                      // El admin puede editar la predicción de cualquiera (sin límite de cierre)
                      isAdmin() ||
                      // El usuario edita su propia predicción antes del cierre
                      (
                        request.auth.uid == existing().userId &&
                        request.time.toMillis() < get(/databases/$(database)/documents/matches/$(existing().matchId)).data.lockTime &&
                        incoming().diff(existing()).affectedKeys().hasOnly(['homeScore', 'awayScore', 'hasPenalties', 'penaltyHome', 'penaltyAway', 'updatedAt'])
                      )
                    );
    }
  }
}
